API_HOST=127.0.0.1
API_PORT=5000
API_DEBUG=false

REQUIRE_API_TOKEN=true
API_TOKEN=change-me-to-a-long-random-secret

FORCE_HEADED_BROWSER=true
DEFAULT_USE_HEADLESS_BROWSER=false

MAX_BROWSER_SESSIONS=1
BROWSER_QUEUE_SIZE=4
BROWSER_SLOT_ACQUIRE_TIMEOUT_SECONDS=5
BROWSER_RESULT_GRACE_SECONDS=10

WAITRESS_THREADS=8
PLAYWRIGHT_EXECUTABLE_PATH=/usr/bin/google-chrome-stable
